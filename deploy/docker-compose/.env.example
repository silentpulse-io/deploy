POSTGRES_DB=silentpulse
POSTGRES_USER=silentpulse
POSTGRES_PASSWORD=silentpulse
POSTGRES_PORT=5432
REDIS_PORT=6379
REDIS_PASSWORD=
JWT_SECRET=dev-only-jwt-secret-min-32-chars!
JWT_EXPIRY=24h
